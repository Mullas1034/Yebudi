# Copy to .env and fill in. Never commit the real .env.

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
# Python worker uses the SQLAlchemy URL form (driver = psycopg v3).
DATABASE_URL=postgresql+psycopg://garmin:garmin@localhost:5432/garmin

# Next.js / node clients use the plain libpq URL form.
DATABASE_URL_NODE=postgres://garmin:garmin@localhost:5432/garmin

# ─────────────────────────────────────────────────────────────
# Ingestion source (the only knob the rest of the system cares about)
#   python-garminconnect | fit-file | official-api
# ─────────────────────────────────────────────────────────────
GARMIN_SOURCE=python-garminconnect

# Credentials for the python-garminconnect adapter.
GARMIN_EMAIL=
GARMIN_PASSWORD=
# Directory where the adapter caches OAuth tokens so we don't log in every run.
GARMIN_TOKEN_STORE=.garmin_tokens
